# DataForge AI Environment Variables

# --- Shared / Database ---
# Get your PostgreSQL connection string (e.g., from Neon.tech or local Docker)
DATABASE_URL="postgresql://user:password@localhost:5432/dataforge"
# Redis connection string (Standard format)
REDIS_URL="redis://localhost:6379"

# --- Backend API (apps/api) ---
PORT=3001
JWT_SECRET="your-super-secret-key"
# Firebase Admin SDK credentials (from Project Settings > Service Accounts)
FIREBASE_PROJECT_ID="dataforge-ai"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-..."
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Scraper Worker (apps/worker) ---
# Get your Gemini API Key from: https://aistudio.google.com/app/apikey
LLM_API_KEY="your-gemini-or-openai-key"
# Optional: Proxy URL (format: http://user:pass@host:port)
PROXY_URL=""
RETRY_LIMIT=3

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Firebase Client SDK credentials (from Project Settings > Apps > Web app)
NEXT_PUBLIC_FIREBASE_API_KEY="..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="..."
NEXT_PUBLIC_FIREBASE_PROJECT_ID="..."
# Stripe Keys (from Stripe Dashboard > Developers > API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Get from Stripe CLI: stripe listen --forward-to localhost:3001/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."
